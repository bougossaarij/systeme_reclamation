{% extends 'base.html.twig' %}

{% block title %}Consulter une réclamation{% endblock %}

{% block body %}

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:      #F0F2F8;
    --surface: #FFFFFF;
    --navy:    #0B1D35;
    --navy2:   #1C3557;
    --red:     #E5334A;
    --teal:    #07B9A0;
    --amber:   #F59000;
    --green:   #0EB07A;
    --muted:   #7D8FA8;
    --border:  #E2E7F0;
    --text:    #16253A;
    --text2:   #475B74;
    --font:    'Sora', sans-serif;
    --mono:    'IBM Plex Mono', monospace;
    --r:       12px;
    --shadow:  0 2px 16px rgba(11,29,53,.09);
    --shadow-l: 0 8px 36px rgba(11,29,53,.14);
  }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 2.5rem 1.5rem;
  }

  .wrap { max-width: 1000px; margin: 0 auto; }

  .back-link {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: .8rem; font-weight: 600; color: var(--muted);
    text-decoration: none; margin-bottom: 1.8rem; transition: color .15s;
  }
  .back-link:hover { color: var(--navy); }

  .page-eyebrow { font-size: .7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--teal); margin-bottom: .35rem; }
  .page-title   { font-size: 1.7rem; font-weight: 800; color: var(--navy); letter-spacing: -.5px; }
  .page-title em { color: var(--red); font-style: normal; }
  .page-sub     { font-size: .8rem; color: var(--muted); margin-top: .3rem; margin-bottom: 2rem; display: flex; align-items: center; gap: 8px; }

  /* ─── BADGE ── */
  .badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 11px; border-radius: 20px;
    font-size: .7rem; font-weight: 700;
  }
  .badge-wait { background: #FFF6E5; color: #B35D00; border: 1.5px solid #FFCB6B; }
  .badge-done { background: #E8FBF5; color: #0A7955; border: 1.5px solid #72E2BE; }
  .badge-dot  { width: 6px; height: 6px; border-radius: 50%; }
  .badge-wait .badge-dot { background: #F59000; }
  .badge-done .badge-dot { background: #0EB07A; }

  /* ─── LAYOUT ── */
  .consult-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 1.5rem; align-items: start;
  }
  @media(max-width:760px) { .consult-grid { grid-template-columns: 1fr; } }

  /* ─── DETAIL CARD ── */
  .detail-card {
    background: var(--surface); border-radius: var(--r);
    box-shadow: var(--shadow); border: 1px solid var(--border);
    overflow: hidden;
  }
  .detail-card-header {
    padding: 1.2rem 1.8rem;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 10px;
  }
  .detail-card-header .icon-badge {
    width: 36px; height: 36px; border-radius: 9px;
    background: linear-gradient(135deg, var(--navy), var(--navy2));
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .detail-card-header h2 { font-size: .92rem; font-weight: 700; color: var(--navy); }

  .detail-body { padding: 0; }
  .detail-row {
    display: grid; grid-template-columns: 130px 1fr;
    padding: 14px 1.8rem;
    border-bottom: 1px solid var(--border);
    align-items: baseline; gap: 1rem;
    transition: background .12s;
  }
  .detail-row:last-child { border-bottom: none; }
  .detail-row:hover { background: #FAFBFF; }
  .dl {
    font-size: .68rem; font-weight: 700; color: var(--muted);
    text-transform: uppercase; letter-spacing: .6px;
  }
  .dv { font-size: .88rem; color: var(--text); line-height: 1.65; }
  .dv-id    { font-family: var(--mono); color: var(--red); font-weight: 600; font-size: .82rem; }
  .dv-name  { font-weight: 700; }
  .dv-email { color: var(--navy2); font-family: var(--mono); font-size: .82rem; }
  .dv-date  { font-family: var(--mono); font-size: .82rem; color: var(--muted); }

  /* ─── SIDE PANEL ── */
  .side-panel { display: flex; flex-direction: column; gap: 1rem; }

  .side-card {
    background: var(--surface); border-radius: var(--r);
    box-shadow: var(--shadow); border: 1px solid var(--border);
    overflow: hidden;
  }
  .side-card-header {
    padding: .9rem 1.2rem;
    border-bottom: 1px solid var(--border);
    font-size: .68rem; font-weight: 700; color: var(--muted);
    text-transform: uppercase; letter-spacing: .7px;
  }
  .side-card-body { padding: 1.1rem; }

  /* ─── STATUS TOGGLE ── */
  .status-option {
    display: flex; align-items: center; justify-content: space-between;
    padding: 11px 13px; border-radius: 9px; border: 2px solid var(--border);
    cursor: pointer; font-size: .84rem; font-weight: 600;
    margin-bottom: .6rem; transition: all .18s;
    text-decoration: none; color: var(--muted);
  }
  .status-option:last-child { margin-bottom: 0; }
  .status-option:hover { border-color: var(--border); background: var(--bg); color: var(--text); }
  .status-option.s-wait { border-color: #FFCB6B; background: #FFF6E5; color: #B35D00; }
  .status-option.s-done { border-color: #72E2BE; background: #E8FBF5; color: #0A7955; }
  .radio-circle {
    width: 17px; height: 17px; border-radius: 50%;
    border: 2px solid currentColor; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .radio-circle::after {
    content: ''; width: 7px; height: 7px; border-radius: 50%;
    background: currentColor; display: none;
  }
  .status-option.s-wait .radio-circle::after,
  .status-option.s-done .radio-circle::after { display: block; }
  .apply-btn {
    width: 100%; margin-top: .8rem; padding: 10px;
    background: var(--teal); color: #fff;
    border: none; border-radius: 9px;
    font-family: var(--font); font-size: .82rem; font-weight: 700;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px;
    transition: box-shadow .15s, transform .15s;
  }
  .apply-btn:hover { box-shadow: 0 5px 18px rgba(7,185,160,.38); transform: translateY(-1px); }

  /* ─── QUICK ACTIONS ── */
  .quick-btn {
    display: flex; align-items: center; gap: 9px;
    width: 100%; padding: 11px 14px; border-radius: 9px;
    font-family: var(--font); font-size: .83rem; font-weight: 600;
    cursor: pointer; border: none; text-decoration: none;
    transition: all .15s; margin-bottom: .6rem;
  }
  .quick-btn:last-child { margin-bottom: 0; }
  .quick-btn-amber { background: rgba(245,144,0,.1); color: #A36000; border: 1.5px solid rgba(245,144,0,.3); }
  .quick-btn-amber:hover { background: var(--amber); color: #fff; box-shadow: 0 4px 14px rgba(245,144,0,.3); transform: translateY(-1px); }
  .quick-btn-red { background: rgba(229,51,74,.08); color: var(--red); border: 1.5px solid rgba(229,51,74,.2); }
  .quick-btn-red:hover { background: var(--red); color: #fff; box-shadow: 0 4px 14px rgba(229,51,74,.3); transform: translateY(-1px); }
  .quick-btn-icon {
    width: 28px; height: 28px; border-radius: 7px; flex-shrink: 0;
    background: rgba(255,255,255,.5);
    display: flex; align-items: center; justify-content: center;
  }

  /* ─── META INFO ── */
  .meta-info {
    padding: .8rem 1.2rem;
    font-size: .72rem; color: var(--muted); text-align: center;
    border-top: 1px solid var(--border); background: #FAFBFD;
    line-height: 1.7;
  }

  /* ─── MODAL ── */
  .modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(11,29,53,.45);
    backdrop-filter: blur(4px);
    z-index: 999;
    align-items: center; justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: var(--surface);
    border-radius: var(--r);
    box-shadow: var(--shadow-l);
    border: 1px solid var(--border);
    padding: 2rem;
    max-width: 400px; width: 90%;
    animation: pop .2s ease;
  }
  @keyframes pop {
    from { transform: scale(.92); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }
  .modal-icon {
    width: 48px; height: 48px; border-radius: 50%;
    background: rgba(229,51,74,.1);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.1rem;
  }
  .modal-title { font-size: 1rem; font-weight: 800; color: var(--navy); text-align: center; margin-bottom: .4rem; }
  .modal-sub   { font-size: .8rem; color: var(--muted); text-align: center; line-height: 1.6; margin-bottom: 1.5rem; }
  .modal-actions { display: flex; gap: .7rem; }
  .modal-actions .btn {
    flex: 1; justify-content: center;
    padding: 10px 16px; border-radius: 9px;
    font-family: var(--font); font-size: .83rem; font-weight: 700;
    cursor: pointer; border: none; text-decoration: none;
    transition: transform .15s, box-shadow .15s;
  }
  .btn-cancel { background: var(--bg); color: var(--muted); border: 1.5px solid var(--border) !important; }
  .btn-cancel:hover { color: var(--text); background: #e8eaf0; }
  .btn-delete { background: var(--red); color: #fff; box-shadow: 0 4px 14px rgba(229,51,74,.3); }
  .btn-delete:hover { box-shadow: 0 7px 22px rgba(229,51,74,.45); transform: translateY(-2px); }
</style>

<div class="wrap">

  <!-- BACK -->
  <a href="{{ path('app_reclamation_index') }}" class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    Retour à la liste
  </a>

  <!-- HEADING -->
  <div class="page-eyebrow">Détail</div>
  <div class="page-title">Réclamation <em>{{ reclamation.id }}</em></div>
  <div class="page-sub">
    Informations complètes &nbsp;·
    {% if reclamation.statut == 'En attente' %}
      <span class="badge badge-wait"><span class="badge-dot"></span>En attente</span>
    {% else %}
      <span class="badge badge-done"><span class="badge-dot"></span>Traitée</span>
    {% endif %}
  </div>

  <!-- GRID -->
  <div class="consult-grid">

    <!-- LEFT: DETAIL -->
    <div class="detail-card">
      <div class="detail-card-header">
        <div class="icon-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2"><circle cx="12" cy="12" r="3"/><path d="M2 12c2.4-4.8 5.4-8 10-8s7.6 3.2 10 8-5.4 8-10 8-7.6-3.2-10-8z"/></svg>
        </div>
        <h2>Informations de la réclamation</h2>
      </div>
      <div class="detail-body">
        <div class="detail-row">
          <span class="dl">Numéro de Réclamation</span>
          <span class="dv dv-id">{{ reclamation.id }}</span>
        </div>
        <div class="detail-row">
          <span class="dl">Nom</span>
          <span class="dv dv-name">{{ reclamation.nom }}</span>
        </div>
        <div class="detail-row">
          <span class="dl">Email</span>
          <span class="dv dv-email">{{ reclamation.email }}</span>
        </div>
        <div class="detail-row">
          <span class="dl">Sujet</span>
          <span class="dv" style="font-weight:600;">{{ reclamation.sujet }}</span>
        </div>
        <div class="detail-row">
          <span class="dl">Message</span>
          <span class="dv" style="white-space:pre-wrap;">{{ reclamation.message ?: 'Aucun message disponible' }}</span>
        </div>
        <div class="detail-row">
          <span class="dl">Statut</span>
          <span class="dv">
            {% if reclamation.statut == 'En attente' %}
              <span class="badge badge-wait"><span class="badge-dot"></span>En attente</span>
            {% else %}
              <span class="badge badge-done"><span class="badge-dot"></span>Traitée</span>
            {% endif %}
          </span>
        </div>
      </div>
    </div>

    <!-- RIGHT: SIDEBAR -->
    <div class="side-panel">
      <!-- QUICK ACTIONS -->
      <div class="side-card">
        <div class="side-card-header">Actions rapides</div>
        <div class="side-card-body">
          <a href="{{ path('app_reclamation_edit', {'id': reclamation.id}) }}" class="quick-btn quick-btn-amber">
            <div class="quick-btn-icon">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
            Modifier cette réclamation
          </a>
          <button type="button" onclick="document.getElementById('deleteModal').classList.add('open')" class="quick-btn quick-btn-red" style="width:100%;">
            <div class="quick-btn-icon">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
            </div>
            Supprimer cette réclamation
          </button>
        </div>
        <div class="meta-info">
          Réclamation #{{ reclamation.id }}<br>
          <strong>{{ reclamation.nom }}</strong>
        </div>
      </div>

    </div>
  </div>

</div>

<!-- MODAL DE CONFIRMATION SUPPRESSION -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal-box">
    <div class="modal-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E5334A" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
    </div>
    <div class="modal-title">Confirmer la suppression</div>
    <div class="modal-sub">Voulez-vous vraiment supprimer la réclamation <strong>#{{ reclamation.id }}</strong> de <strong>{{ reclamation.nom }}</strong> ? Cette action est irréversible.</div>
    <div class="modal-actions">
      <button type="button" class="btn btn-cancel" onclick="document.getElementById('deleteModal').classList.remove('open')">Annuler</button>
      <form method="post" action="{{ path('app_reclamation_delete', {'id': reclamation.id}) }}" style="flex:1;display:flex;">
        <input type="hidden" name="_method" value="DELETE">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reclamation.id) }}">
        <button type="submit" class="btn btn-delete" style="flex:1;">Supprimer</button>
      </form>
    </div>
  </div>
</div>

{% endblock %}