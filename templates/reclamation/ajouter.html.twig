{% extends 'base.html.twig' %}

{% block title %}Ajouter une réclamation{% endblock %}

{% block body %}

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:      #F0F2F8;
    --surface: #FFFFFF;
    --navy:    #0B1D35;
    --navy2:   #1C3557;
    --red:     #E5334A;
    --teal:    #07B9A0;
    --amber:   #F59000;
    --muted:   #7D8FA8;
    --border:  #E2E7F0;
    --text:    #16253A;
    --text2:   #475B74;
    --font:    'Sora', sans-serif;
    --r:       12px;
    --shadow:  0 2px 16px rgba(11,29,53,.09);
  }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 2.5rem 1.5rem;
  }

  .wrap { max-width: 720px; margin: 0 auto; }

  /* ─── BACK LINK ── */
  .back-link {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: .8rem; font-weight: 600; color: var(--muted);
    text-decoration: none; margin-bottom: 1.8rem;
    transition: color .15s;
  }
  .back-link:hover { color: var(--navy); }

  /* ─── PAGE TITLE ── */
  .page-eyebrow { font-size: .7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--teal); margin-bottom: .35rem; }
  .page-title   { font-size: 1.7rem; font-weight: 800; color: var(--navy); letter-spacing: -.5px; }
  .page-title em { color: var(--red); font-style: normal; }
  .page-sub { font-size: .8rem; color: var(--muted); margin-top: .3rem; margin-bottom: 2rem; }

  /* ─── CARD ── */
  .form-card {
    background: var(--surface);
    border-radius: var(--r);
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .form-card-header {
    padding: 1.3rem 2rem;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 10px;
  }
  .form-card-header .icon-badge {
    width: 38px; height: 38px; border-radius: 9px;
    background: linear-gradient(135deg, var(--teal), #05D4B8);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .form-card-header h2 { font-size: .95rem; font-weight: 700; color: var(--navy); }
  .form-card-header p  { font-size: .76rem; color: var(--muted); margin-top: 2px; }

  .form-body { padding: 2rem; }

  /* ─── FIELDS ── */
  .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
  @media(max-width:560px) { .row2 { grid-template-columns: 1fr; } }

  .field { margin-bottom: 1.3rem; }
  .field:last-child { margin-bottom: 0; }

  .field label {
    display: flex; align-items: center; gap: 6px;
    font-size: .74rem; font-weight: 700;
    color: var(--text2); text-transform: uppercase;
    letter-spacing: .6px; margin-bottom: 7px;
  }
  .field label .required { color: var(--red); }

  .field input, .field textarea {
    width: 100%;
    padding: 11px 14px;
    border: 1.5px solid var(--border);
    border-radius: 9px;
    font-family: var(--font); font-size: .88rem; color: var(--text);
    background: #FAFBFD;
    outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
  }
  .field input::placeholder,
  .field textarea::placeholder { color: #BCC8D8; }
  .field input:focus,
  .field textarea:focus {
    border-color: var(--teal);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(7,185,160,.1);
  }
  .field textarea { resize: vertical; min-height: 120px; line-height: 1.65; }

  /* ─── DIVIDER ── */
  .divider {
    border: none; border-top: 1px solid var(--border);
    margin: 1.6rem 0;
  }

  /* ─── ACTIONS ── */
  .form-actions {
    display: flex; gap: .8rem; flex-wrap: wrap; align-items: center;
  }

  /* ─── BUTTONS ── */
  .btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 11px 22px; border-radius: 9px;
    font-family: var(--font); font-size: .84rem; font-weight: 700;
    cursor: pointer; border: none; text-decoration: none;
    transition: transform .15s, box-shadow .15s;
  }
  .btn:hover  { transform: translateY(-2px); }
  .btn:active { transform: translateY(0); }
  .btn-teal  { background: var(--teal);   color: #fff; box-shadow: 0 4px 14px rgba(7,185,160,.32); }
  .btn-teal:hover { box-shadow: 0 7px 22px rgba(7,185,160,.44); }
  .btn-ghost { background: transparent; color: var(--muted); border: 1.5px solid var(--border); box-shadow: none; }
  .btn-ghost:hover { color: var(--text); background: var(--bg); }

  /* ─── INFO TIP ── */
  .info-tip {
    display: flex; align-items: flex-start; gap: 9px;
    background: #EBF6FF; border: 1px solid #C3E0FF;
    border-radius: 9px; padding: 11px 14px; margin-bottom: 1.5rem;
    font-size: .78rem; color: #1A5FA8; line-height: 1.5;
  }
  .info-tip svg { flex-shrink: 0; margin-top: 1px; }
</style>

<div class="wrap">

  <!-- BACK -->
  <a href="{{ path('app_reclamation_index') }}" class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    Retour à la liste
  </a>

  <!-- HEADING -->
  <div class="page-eyebrow">Formulaire</div>
  <div class="page-title">Déposer une <em>réclamation</em></div>
  <div class="page-sub">Remplissez tous les champs obligatoires pour soumettre votre demande</div>

  <!-- INFO TIP -->
  <div class="info-tip">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    Votre réclamation sera traitée sous 48h ouvrées. Un email de confirmation vous sera envoyé.
  </div>

  <!-- CARD -->
  <div class="form-card">
    <div class="form-card-header">
      <div class="icon-badge">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
      </div>
      <div>
        <h2>Nouvelle réclamation</h2>
        <p>Tous les champs marqués * sont obligatoires</p>
      </div>
    </div>

    <div class="form-body">
      <form method="post">

        <div class="row2">
          <div class="field">
            <label>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Nom complet <span class="required">*</span>
            </label>
            <input type="text" name="nom" placeholder="Ex : Ahmed Ben Ali" required autocomplete="name">
          </div>
          <div class="field">
            <label>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              Email <span class="required">*</span>
            </label>
            <input type="email" name="email" placeholder="Ex : ahmed@example.com" required autocomplete="email">
          </div>
        </div>

        <div class="field">
          <label>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            Sujet <span class="required">*</span>
          </label>
          <input type="text" name="sujet" placeholder="Résumez votre problème en quelques mots" required>
        </div>

        <div class="field">
          <label>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            Message détaillé <span class="required">*</span>
          </label>
          <textarea name="message" placeholder="Décrivez votre situation en détail : dates, références, ce que vous avez déjà essayé…" required></textarea>
        </div>

        <hr class="divider">

        <div class="form-actions">
          <button type="submit" class="btn btn-teal">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Envoyer la réclamation
          </button>
          <a href="{{ path('app_reclamation_index') }}" class="btn btn-ghost">Annuler</a>
        </div>

      </form>
    </div>
  </div>

</div>

{% endblock %}