{% extends 'base.html.twig' %}

{% block title %}Liste des réclamations{% endblock %}

{% block body %}

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:      #F0F2F8;
    --surface: #FFFFFF;
    --navy:    #0B1D35;
    --red:     #E5334A;
    --teal:    #07B9A0;
    --muted:   #7D8FA8;
    --border:  #E2E7F0;
    --text:    #16253A;
    --text2:   #475B74;
    --font:    'Sora', sans-serif;
    --r:       12px;
    --shadow:  0 2px 16px rgba(11,29,53,.09);
  }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 2.5rem 1.5rem;
  }

  .wrap { max-width: 900px; margin: 0 auto; }

  /* ─── HEADER ROW ── */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.8rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .page-title { font-size: 1.7rem; font-weight: 800; color: var(--navy); letter-spacing: -.5px; }
  .page-title em { color: var(--red); font-style: normal; }
  .page-eyebrow { font-size: .7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--teal); margin-bottom: .3rem; }

  /* ─── BUTTONS ── */
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 18px; border-radius: 9px;
    font-family: var(--font); font-size: .82rem; font-weight: 700;
    cursor: pointer; border: none; text-decoration: none;
    transition: transform .15s, box-shadow .15s;
  }
  .btn:hover  { transform: translateY(-2px); }
  .btn:active { transform: translateY(0); }
  .btn-teal   { background: var(--teal); color: #fff; box-shadow: 0 4px 14px rgba(7,185,160,.32); }
  .btn-teal:hover { box-shadow: 0 7px 22px rgba(7,185,160,.44); }
  .btn-warning { background: #F59000; color: #fff; box-shadow: 0 4px 14px rgba(245,144,0,.28); }
  .btn-warning:hover { box-shadow: 0 7px 22px rgba(245,144,0,.4); }
  .btn-red { background: var(--red); color: #fff; box-shadow: 0 4px 14px rgba(229,51,74,.28); }
  .btn-red:hover { box-shadow: 0 7px 22px rgba(229,51,74,.4); }
  .btn-ghost  { background: transparent; color: var(--muted); border: 1.5px solid var(--border); box-shadow: none; }
  .btn-ghost:hover { color: var(--text); background: var(--bg); }

  /* ─── TABLE CARD ── */
  .table-card {
    background: var(--surface);
    border-radius: var(--r);
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    overflow: hidden;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead tr {
    background: #F5F7FB;
    border-bottom: 2px solid var(--border);
  }

  th {
    padding: 13px 18px;
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .7px;
    color: var(--muted);
    text-align: left;
  }

  tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background .15s;
  }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: #F8FAFD; }

  td {
    padding: 13px 18px;
    font-size: .87rem;
    color: var(--text2);
    vertical-align: middle;
  }

  /* ─── STATUS BADGES ── */
  .badge {
    display: inline-block;
    padding: 4px 11px;
    border-radius: 20px;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .4px;
  }
  .badge-open    { background: #FFF3E0; color: #E65100; }
  .badge-closed  { background: #E8F5E9; color: #2E7D32; }
  .badge-pending { background: #E3F2FD; color: #1565C0; }

  /* ─── EMPTY STATE ── */
  .empty-state {
    text-align: center;
    padding: 3.5rem 1rem;
    color: var(--muted);
    font-size: .88rem;
  }
  .empty-state a { color: var(--teal); font-weight: 600; text-decoration: none; }
  .empty-state a:hover { text-decoration: underline; }

  /* ─── ACTION BUTTONS IN TABLE ── */
  .actions { display: flex; gap: .4rem; align-items: center; }
  .actions form { margin: 0; }

  /* ─── CUSTOM MODAL ── */
  .modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(11, 29, 53, 0.4);
    backdrop-filter: blur(4px);
    display: none; align-items: center; justify-content: center;
    z-index: 1000; opacity: 0; transition: opacity .3s ease;
  }
  .modal-overlay.active { display: flex; opacity: 1; }
  
  .modal-card {
    background: #fff; width: 100%; max-width: 400px;
    padding: 2.5rem 2rem; border-radius: 24px;
    text-align: center; box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    transform: translateY(20px); transition: transform .3s ease;
  }
  .modal-overlay.active .modal-card { transform: translateY(0); }

  .modal-icon {
    width: 60px; height: 60px; background: #FFF1F2;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.5rem; color: #E5334A;
  }
  .modal-title { font-size: 1.25rem; font-weight: 800; color: var(--navy); margin-bottom: .8rem; }
  .modal-text { font-size: .95rem; color: var(--muted); line-height: 1.5; margin-bottom: 2rem; }
  .modal-text em { color: var(--text); font-weight: 700; font-style: normal; }

  .modal-actions { display: flex; gap: 1rem; }
  .modal-btn {
    flex: 1; padding: 12px; border-radius: 12px; font-weight: 700; font-size: .9rem;
    cursor: pointer; border: none; transition: all .2s;
  }
  .btn-cancel { background: #F0F2F8; color: var(--text2); }
  .btn-cancel:hover { background: #E2E7F0; }
  .btn-confirm { background: #E5334A; color: #fff; box-shadow: 0 4px 12px rgba(229,51,74,0.3); }
  .btn-confirm:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(229,51,74,0.4); }
</style>

<div class="wrap">

  <!-- HEADER -->
  <div class="page-header">
    <div>
      <div class="page-eyebrow">Gestion</div>
      <div class="page-title">Liste des <em>réclamations</em></div>
    </div>
    <a href="{{ path('app_reclamation_new') }}" class="btn btn-teal">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Ajouter une réclamation
    </a>
  </div>

  <!-- TABLE -->
  <div class="table-card">
    <table>
      <thead>
        <tr>
          <th>Nom</th>
          <th>Email</th>
          <th>Sujet</th>
          <th>Statut</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for reclamation in reclamations %}
        <tr>
          <td>{{ reclamation.nom }}</td>
          <td>{{ reclamation.email }}</td>
          <td>{{ reclamation.sujet }}</td>
          <td>
            {% if reclamation.statut == 'En attente' %}
              <span class="badge badge-open">En attente</span>
            {% elseif reclamation.statut == 'Traitée' %}
              <span class="badge badge-closed">Traitée</span>
            {% else %}
              <span class="badge badge-pending">En cours</span>
            {% endif %}
          </td>
          <td>
            <div class="actions">
              <a href="{{ path('app_reclamation_show', {'id': reclamation.id}) }}" class="btn btn-ghost">Voir</a>
              <a href="{{ path('app_reclamation_edit', {'id': reclamation.id}) }}" class="btn btn-warning">Modifier</a>
              <form method="post" action="{{ path('app_reclamation_delete', {'id': reclamation.id}) }}" class="delete-form">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reclamation.id) }}">
                  <button type="button" class="btn btn-red delete-trigger" 
                          data-id="{{ reclamation.id }}" 
                          data-name="{{ reclamation.nom }}">Supprimer</button>
              </form>
            </div>
          </td>
        </tr>
        {% else %}
        <tr>
          <td colspan="5">
            <div class="empty-state">
              Aucune réclamation enregistrée.
              <a href="{{ path('app_reclamation_new') }}">Ajoutez votre première réclamation</a>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

</div>

<!-- CUSTOM DELETE MODAL -->
<div id="deleteModal" class="modal-overlay">
  <div class="modal-card">
    <div class="modal-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
    </div>
    <div class="modal-title">Confirmer la suppression</div>
    <div class="modal-text">
        Voulez-vous vraiment supprimer la réclamation <em id="modalRecName">#0</em> ? 
        Cette action est irréversible.
    </div>
    <div class="modal-actions">
      <button class="modal-btn btn-cancel" id="cancelBtn">Annuler</button>
      <button class="modal-btn btn-confirm" id="confirmBtn">Supprimer</button>
    </div>
  </div>
</div>

<script>
    let activeForm = null;
    const modal = document.getElementById('deleteModal');
    const modalText = document.getElementById('modalRecName');

    document.querySelectorAll('.delete-trigger').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            activeForm = this.closest('form');
            modalText.textContent = "#" + this.dataset.id + " de " + this.dataset.name;
            modal.classList.add('active');
        });
    });

    document.getElementById('cancelBtn').addEventListener('click', () => {
        modal.classList.remove('active');
        activeForm = null;
    });

    document.getElementById('confirmBtn').addEventListener('click', () => {
        if (activeForm) activeForm.submit();
    });

    // Fermer si clic en dehors
    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.classList.remove('active');
            activeForm = null;
        }
    });
</script>
{% endblock %}
